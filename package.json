{
  "name": "reading-ruler",
  "version": "0.1.0",
  "description": "Cross-platform desktop reading ruler overlay with multiple customizable rulers, window targeting, and macOS packaging.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bilalalissa/Reading-Ruler.git"
  },
  "homepage": "https://github.com/bilalalissa/Reading-Ruler#readme",
  "bugs": {
    "url": "https://github.com/bilalalissa/Reading-Ruler/issues"
  },
  "scripts": {
    "deps:check:mac": "./script/check_macos_deps.sh",
    "deps:check:windows": "powershell -ExecutionPolicy Bypass -File script/check_windows_deps.ps1",
    "dev": "cargo run --manifest-path src-tauri/Cargo.toml",
    "build": "cargo build --manifest-path src-tauri/Cargo.toml",
    "app:build": "tauri build",
    "app:package:mac": "./script/build_macos_app.sh",
    "app:package:mac:local": "./script/package_macos_local.sh",
    "app:package:mac:distribution": "./script/package_macos_distribution.sh",
    "app:package:windows:local": "powershell -ExecutionPolicy Bypass -File script/package_windows_local.ps1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3"
  }
}
